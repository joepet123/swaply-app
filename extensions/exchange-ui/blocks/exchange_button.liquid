{% if order %}
  <div id="swaply-exchange-container" 
       data-order-id="{{ order.id }}" 
       data-order-number="{{ order.name }}"
       data-customer-email="{{ order.email }}"
       data-customer-name="{{ order.customer.name }}"
       data-shop="{{ shop.permanent_domain }}">
    
    <h3 class="swaply-title">Need a different size or color?</h3>
    <p class="swaply-subtitle">Exchange items from this order easily.</p>
    
    <div class="swaply-items-list">
      {% for line_item in order.line_items %}
        <div class="swaply-item" data-line-item-id="{{ line_item.id }}">
          <div class="swaply-item-info">
            <span class="swaply-item-name">{{ line_item.title }}</span>
            <span class="swaply-item-variant">{{ line_item.variant.title }}</span>
          </div>
          <button class="swaply-exchange-btn" 
                  data-line-item-id="{{ line_item.id }}"
                  data-product-title="{{ line_item.product.title }}"
                  data-variant-title="{{ line_item.variant.title }}">
            Exchange
          </button>
        </div>
      {% endfor %}
    </div>
  </div>

  <div id="swaply-modal" class="swaply-modal" style="display:none;">
    <div class="swaply-modal-content">
      <span class="swaply-close">&times;</span>
      <h2>Select Exchange Item</h2>
      <div id="swaply-product-search">
        <input type="text" id="swaply-search-input" placeholder="Search products...">
      </div>
      <div id="swaply-product-list" class="swaply-grid">
        <!-- Products will be loaded here -->
      </div>
      <div id="swaply-selection-summary" style="display:none;">
        <hr>
        <h3>Selected Item:</h3>
        <div id="swaply-selected-item-details"></div>
        <textarea id="swaply-customer-note" placeholder="Add a note (optional)..."></textarea>
        <button id="swaply-submit-request" class="swaply-primary-btn">Submit Exchange Request</button>
      </div>
    </div>
  </div>
{% endif %}

{% schema %}
{
  "name": "Swaply Exchange Button",
  "target": "section",
  "stylesheet": "swaply.css",
  "javascript": "swaply.js",
  "settings": [
    { "type": "color", "id": "btn_color", "label": "Button Color", "default": "#6c63ff" }
  ]
}
{% endschema %}
